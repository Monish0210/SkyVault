# Server port for Express API
PORT=5000

# Runtime environment
NODE_ENV=development

# MongoDB Atlas connection string
MONGODB_URI=<your-mongodb-connection-string>

# JWT signing secret (use a random 64-char hex string)
JWT_SECRET=replace-with-64-char-hex-secret

# AWS region (sandbox is locked to us-east-1)
AWS_REGION=us-east-1

# AWS access key from sandbox Details panel
AWS_ACCESS_KEY_ID=replace-with-sandbox-access-key-id

# AWS secret key from sandbox Details panel
AWS_SECRET_ACCESS_KEY=replace-with-sandbox-secret-access-key

# Required for sandbox/temporary AWS credentials
AWS_SESSION_TOKEN=replace-with-sandbox-session-token

# S3 bucket for SkyVault files
S3_BUCKET_NAME=skyvault-files-your-unique-suffix

